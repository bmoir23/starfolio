---
import Layout from "@/layouts/Layout.astro";
import { getProjects, isSanityConfigured } from "@/lib/sanity";
import { ProjectCard } from "@/components/project-card";
import { DATA } from "@/data/resume";
import type { ProjectSummary } from "@/lib/sanity";

export const prerender = false;

const configured = isSanityConfigured();
let projects: ProjectSummary[] = [];
let fetchError: string | null = null;

if (configured) {
  try {
    projects = await getProjects(50);
  } catch (e) {
    fetchError = e instanceof Error ? e.message : "Failed to fetch projects";
  }
}
---

<Layout title="Projects">
  <main class="min-h-dvh flex flex-col gap-10">
    <section class="flex flex-col gap-y-3 items-center justify-center pt-4">
      <div class="flex items-center w-full">
        <div class="flex-1 h-px bg-linear-to-r from-transparent from-5% via-border via-95% to-transparent"></div>
        <div class="border bg-primary z-10 rounded-xl px-4 py-1">
          <span class="text-background text-sm font-medium">{DATA.sections.projects.label}</span>
        </div>
        <div class="flex-1 h-px bg-linear-to-l from-transparent from-5% via-border via-95% to-transparent"></div>
      </div>
      <h1 class="text-3xl font-bold tracking-tighter sm:text-4xl">{DATA.sections.projects.heading}</h1>
      <p class="text-muted-foreground md:text-lg/relaxed lg:text-base/relaxed text-balance text-center max-w-xl">
        {DATA.sections.projects.text}
      </p>
    </section>

    {!configured && (
      <section class="rounded-xl border border-dashed border-border bg-muted/40 p-8 text-center">
        <p class="text-sm text-muted-foreground max-w-md mx-auto">
          Sanity isn't configured yet. Add <code class="text-foreground">SANITY_PROJECT_ID</code> and
          <code class="text-foreground">SANITY_DATASET</code> to your environment to start publishing projects.
        </p>
      </section>
    )}

    {configured && fetchError && (
      <section class="rounded-xl border border-destructive/30 bg-destructive/10 p-6 text-center">
        <p class="text-sm text-destructive">Couldn't load projects: {fetchError}</p>
      </section>
    )}

    {configured && !fetchError && projects.length === 0 && (
      <section class="rounded-xl border border-dashed border-border bg-muted/40 p-8 text-center">
        <p class="text-sm text-muted-foreground max-w-md mx-auto">
          No projects yet. Check back soon — I'll be showcasing the AI platforms and pipelines I've built here.
        </p>
      </section>
    )}

    {configured && !fetchError && projects.length > 0 && (
      <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 auto-rows-fr">
        {projects.map((project) => (
          <ProjectCard
            client:visible
            slug={project.slug}
            title={project.title}
            description={project.excerpt}
            dates={project.dates}
            tags={project.technologies}
            image={project.coverImageUrl}
            githubUrl={project.githubUrl}
            websiteUrl={project.websiteUrl}
          />
        ))}
      </section>
    )}
  </main>
</Layout>
