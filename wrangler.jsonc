{
	"compatibility_date": "2026-04-30",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "starfolio",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"analytics_engine_datasets": [
    { "binding": "ANALYTICS_ENGINE", "dataset": "dev_portfolio" }
  ],
	"observability": {
		"enabled": true
	}
}