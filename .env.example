# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# Create a project at https://www.sanity.io/manage and fill these in.
# Copy this file to `.dev.vars` (for local astro dev / wrangler) and add the
# same keys as secrets in your Cloudflare project for production.
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-10-01
# Optional — only required if your dataset is private.
SANITY_API_TOKEN=

# ─── Contact form ────────────────────────────────────────────────────────────
# The /api/contact endpoint stores submissions in Neon and/or forwards them to
# an n8n webhook. Configure at least one of the following.
#
# Neon Postgres connection string (https://console.neon.tech → your project →
# Connection Details → "Pooled connection"). See CONTACT.md for the table schema.
NEON_DATABASE_URL=
# Alias also accepted by the endpoint:
# DATABASE_URL=

# n8n webhook that receives the submission (then syncs to Notion + routes email).
N8N_CONTACT_WEBHOOK_URL=
