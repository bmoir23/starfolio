# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# Create a project at https://www.sanity.io/manage and fill these in.
# Copy this file to `.dev.vars` (for local astro dev / wrangler) and add the
# same keys as secrets in your Cloudflare project for production.
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-10-01
# Optional — only required if your dataset is private.
SANITY_API_TOKEN=
